Bootstrap: docker
From: nvidia/cuda:12.6.3-devel-ubuntu24.04

%files
    Cargo.toml /app/Cargo.toml
    Cargo.lock /app/Cargo.lock
    src /app/src
    build.rs /app/build.rs
    cuda /app/cuda

%post
    apt-get update && \
    apt-get install -y \
        curl gcc g++ make pkg-config libssl-dev && \
    apt-get autoremove && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install Rust
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    export PATH="/root/.cargo/bin:$PATH"

    # Build all binaries with CUDA support
    cd /app
    CUDA_HOME=/usr/local/cuda cargo build --release --no-default-features --features cuda \
        --bin gpu-batch \
        --bin gpu-scaling-bench \
        --bin cpu-scaling-bench

    cp /app/target/release/gpu-batch /app/gpu-batch
    cp /app/target/release/gpu-scaling-bench /app/gpu-scaling-bench
    cp /app/target/release/cpu-scaling-bench /app/cpu-scaling-bench

%environment
    export CUDA_HOME="/usr/local/cuda"
    export LD_LIBRARY_PATH="/usr/local/cuda/lib64:$LD_LIBRARY_PATH"

%runscript
    exec /app/gpu-batch "$@"
